{{!
    @template tiny_c4l/modal

    Modal to manage components within the Tiny Editor.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:

    Example context (json):
    {
        "elementid": "exampleId",
        "filters" : [
            {"name": "Contextual"},
            {"type": "contextual"},
            {"filterClass": ""}
        ],
        "buttons": [
          {"id": "randomid"},
          {"imageClass": "c4l-classname"},
          {"name": "component name"},
          {"htmlcode": "<div>Text</div>"}
        ],
        "preview": "true"
    }
}}
{{< core/modal }}
    {{$title}}
        {{#str}} pluginname, tiny_c4l {{/str}}
    {{/title}}
    {{$body}}
        <div id="{{elementid}}" class="c4l-plugin-container">
            <div class="c4l-select-filters">
                <select class="c4l-select-filter" aria-controls="c4l-buttons-grid">
                    {{#filters}}
                        <option value="{{type}}">{{name}}</option>
                    {{/filters}}
                </select>
            </div>
            <div class="c4l-buttons-filters">
                {{#filters}}
                    <button class="c4l-button-filter {{filterClass}}" data-filter="{{type}}" aria-controls="c4l-buttons-grid">
                            {{name}}
                    </button>
                {{/filters}}
            </div>
            <div class="c4l-buttons-preview {{^preview}}c4l-no-preview{{/preview}}">
                <div id="c4l-buttons-grid" class="c4l-buttons-grid">
                    {{#buttons}}
                        <button
                            class="c4lt-dialog-button {{imageClass}}"
                            data-id="{{id}}"
                            data-type="{{type}}"
                            data-classcomponent="{{classComponent}}"
                        >
                            <span class="c4l-button-text">
                                {{#icon}}
                                    <i class="icon" style="background-image: url({{icon}});"></i>
                                {{/icon}}
                                {{{name}}}
                            </span>
                            <span class="c4l-button-variants">
                            {{#variants}}
                                <span
                                    class="c4l-button-variant {{imageClass}}"
                                    data-variant="{{name}}"
                                    data-state="{{state}}"
                                    data-toggle="tooltip"
                                    data-placement="top"
                                    title="{{title}}"
                                ></span>
                            {{/variants}}
                            </span>
                        </button>
                    {{/buttons}}
                </div>
                {{#showAside}}
                <div class="c4l-modal-aside {{^preview}}c4l-docs-only{{/preview}}">
                    <div class="c4l-aside-header">
                        {{#docs}}
                        <button class="c4l-tab-docs {{^preview}}c4l-tab-active{{/preview}}" type="button" {{^bothEnabled}}disabled{{/bothEnabled}}>
                            {{#str}} docs, tiny_c4l {{/str}}
                        </button>
                        {{/docs}}
                        {{#preview}}
                        <button class="c4l-tab-preview {{#preview}}c4l-tab-active{{/preview}}" type="button" {{^bothEnabled}}disabled{{/bothEnabled}}>
                            {{#str}} preview, tiny_c4l {{/str}}
                        </button>
                        {{/preview}}
                    </div>
                    <div class="c4l-aside-slider">
                        <div class="c4l-code-preview">
                            <div data-id="code-preview-default">
                                <div class="c4l-preview-default">{{#str}} previewdefault, tiny_c4l {{/str}}</div>
                            </div>
                            {{#buttons}}
                            <div data-id="code-preview-{{id}}" class="c4l-component-code {{#css}}c4l-component-custom-code{{/css}} c4l-hidden" role="presentation" style="{{css}}">{{{htmlcode}}}</div>
                            {{/buttons}}
                        </div>
                        <div class="c4l-code-docs">
                            <div data-id="code-docs-default">
                                <div class="c4l-docs-default">{{#str}} previewdocsdefault, tiny_c4l {{/str}}</div>
                            </div>
                            {{#buttons}}
                            <div data-id="code-docs-{{id}}" class="c4l-docs-content c4l-hidden">
                                {{#docsData}}
                                <p class="c4l-docs-description">{{{description}}}</p>
                                {{#hasUseCases}}
                                <div class="c4l-docs-section">
                                    <h5 class="c4l-docs-heading">{{#str}} docs_usecases, tiny_c4l {{/str}}</h5>
                                    <ul class="c4l-docs-list">
                                        {{#useCases}}
                                        <li>{{{text}}}</li>
                                        {{/useCases}}
                                    </ul>
                                </div>
                                {{/hasUseCases}}
                                {{/docsData}}
                            </div>
                            {{/buttons}}
                        </div>
                    </div>
                </div>
                {{/showAside}}
            </div>
        </div>
    {{/body}}
{{/ core/modal }}
{{#js}}
    require(['jquery'], function($) {
      $('[data-toggle="tooltip"]').tooltip();
    });
{{/js}}
